# Non-secret AHRI TRE profile for an identity-bound datastore.
# Ordinary users only need the datastore identity handed off by the operator.
# The datastore binding resolves DuckLake catalog, lake path, encryption,
# and managed catalog credential details from metadata.
TRE_DATASTORE=<datastore-name>

# Add optional connection or OAuth settings only when your operator provides them.
# TRE_SERVER=<postgres-hostname>
# TRE_PORT=5432
# TRE_SSLMODE=require
# ORCID_ISSUER=https://orcid.org
# ORCID_CLIENT_ID=<oauth-client-id>
# ORCID_REDIRECT_URI=http://127.0.0.1:8890/callback
# ORCID_SCOPE=openid
