{
  "name": "ahriTRErRs",
  "dockerComposeFile": "docker_compose.yml",
  "service": "r",
  "workspaceFolder": "/workspaces/ahriTRErRs",
  "remoteUser": "vscode",
  "features": {},
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "terminal.integrated.env.linux": {
          "ALLOW_OVERMOUNT_CIFS": "1"
        }
      },
      "extensions": [
        "REditorSupport.r",
        "rdebugger.r-debugger"
      ]
    }
  },
  "postCreateCommand": "bash /usr/local/bin/post_create_setup.sh",
  "updateContentCommand": "bash /usr/local/bin/post_create_setup.sh"
}
