{
  "name": "ahriTRErRs",
  "dockerComposeFile": "docker_compose.yml",
  "service": "r",
  "workspaceFolder": "/workspaces/ahriTRErRs",
  "remoteUser": "vscode",
  "features": {},
  "customizations": {
    "vscode": {
      "extensions": [
        "REditorSupport.r",
        "rdebugger.r-debugger"
      ]
    }
  },
  "postCreateCommand": "R -q -f tools/ensure_dependencies.R",
  "updateContentCommand": "R -q -f tools/ensure_dependencies.R"
}
